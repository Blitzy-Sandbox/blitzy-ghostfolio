COMPOSE_PROJECT_NAME=ghostfolio

# CACHE
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=<INSERT_REDIS_PASSWORD>

# POSTGRES
POSTGRES_DB=ghostfolio-db
POSTGRES_USER=user
POSTGRES_PASSWORD=<INSERT_POSTGRES_PASSWORD>

# VARIOUS
ACCESS_TOKEN_SALT=<INSERT_RANDOM_STRING>
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}?connect_timeout=300
JWT_SECRET_KEY=<INSERT_RANDOM_STRING>

# AI / SNOWFLAKE (added by Agent Action Plan)

# AI PROVIDER SELECTION (Refine PR Directive 1)
# Selects which large language model backs the AI Portfolio Chat Agent (Feature B)
# and the Explainable Rebalancing Engine (Feature C). Supported values:
#   - anthropic   Claude API via @ai-sdk/anthropic   (requires ANTHROPIC_API_KEY)
#   - openai      OpenAI API via @ai-sdk/openai      (requires OPENAI_API_KEY)
#   - google      Gemini via @ai-sdk/google          (requires GOOGLE_API_KEY)
#   - ollama      Local Ollama via OpenAI-compat /v1 (requires OLLAMA_BASE_URL)
# Default when unset: anthropic
AI_PROVIDER=anthropic

# Optional model identifier override. When unset (or empty), the AiProviderService
# falls back to the provider's default model:
#   - anthropic → claude-3-5-sonnet-20241022
#   - openai    → gpt-4o
#   - google    → gemini-1.5-pro
#   - ollama    → llama3.1
AI_MODEL=

# ANTHROPIC (used when AI_PROVIDER=anthropic)
ANTHROPIC_API_KEY=<INSERT_ANTHROPIC_API_KEY>

# OPENAI (used when AI_PROVIDER=openai)
OPENAI_API_KEY=<INSERT_OPENAI_API_KEY>

# GOOGLE (used when AI_PROVIDER=google)
GOOGLE_API_KEY=<INSERT_GOOGLE_API_KEY>

# OLLAMA (used when AI_PROVIDER=ollama)
# Base URL of the Ollama OpenAI-compatible endpoint. Default for local
# development is http://localhost:11434/v1.
OLLAMA_BASE_URL=http://localhost:11434/v1

# SNOWFLAKE
SNOWFLAKE_ACCOUNT=<INSERT_SNOWFLAKE_ACCOUNT>
SNOWFLAKE_USER=<INSERT_SNOWFLAKE_USER>
SNOWFLAKE_PASSWORD=<INSERT_SNOWFLAKE_PASSWORD>
SNOWFLAKE_DATABASE=<INSERT_SNOWFLAKE_DATABASE>
SNOWFLAKE_WAREHOUSE=<INSERT_SNOWFLAKE_WAREHOUSE>
SNOWFLAKE_SCHEMA=<INSERT_SNOWFLAKE_SCHEMA>
