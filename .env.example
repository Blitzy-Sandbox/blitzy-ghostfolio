COMPOSE_PROJECT_NAME=ghostfolio

# CACHE
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=<INSERT_REDIS_PASSWORD>

# POSTGRES
POSTGRES_DB=ghostfolio-db
POSTGRES_USER=user
POSTGRES_PASSWORD=<INSERT_POSTGRES_PASSWORD>

# VARIOUS
ACCESS_TOKEN_SALT=<INSERT_RANDOM_STRING>
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}?connect_timeout=300
JWT_SECRET_KEY=<INSERT_RANDOM_STRING>

# AI / SNOWFLAKE (added by Agent Action Plan)

# SNOWFLAKE
SNOWFLAKE_ACCOUNT=<INSERT_SNOWFLAKE_ACCOUNT>
SNOWFLAKE_USER=<INSERT_SNOWFLAKE_USER>
SNOWFLAKE_PASSWORD=<INSERT_SNOWFLAKE_PASSWORD>
SNOWFLAKE_DATABASE=<INSERT_SNOWFLAKE_DATABASE>
SNOWFLAKE_WAREHOUSE=<INSERT_SNOWFLAKE_WAREHOUSE>
SNOWFLAKE_SCHEMA=<INSERT_SNOWFLAKE_SCHEMA>

# ANTHROPIC
ANTHROPIC_API_KEY=<INSERT_ANTHROPIC_API_KEY>
